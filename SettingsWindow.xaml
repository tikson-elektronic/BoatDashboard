<Window x:Class="BoatDashboard.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="560" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="Lbl">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="2,12,0,4"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource TrackBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="9,7"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{StaticResource TrackBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="9,7"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Border>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{StaticResource BgTop}" Offset="0"/>
                <GradientStop Color="{StaticResource BgBottom}" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Grid Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Settings" Foreground="{StaticResource TextBrush}" FontSize="22" FontWeight="Bold"/>

                <TextBlock Text="CLAUDE AI" Style="{StaticResource SectionTitle}" Margin="0,18,0,2"/>
                <TextBlock Text="API key" Style="{StaticResource Lbl}"/>
                <PasswordBox x:Name="ApiKeyBox"/>
                <TextBlock Text="Stored locally in %AppData%\BoatDashboard. Used for the onboard assistant."
                           Foreground="{StaticResource MutedBrush}" FontSize="10" Margin="2,4,0,0" TextWrapping="Wrap"/>

                <TextBlock Text="MQTT PUBLISHING" Style="{StaticResource SectionTitle}" Margin="0,20,0,2"/>
                <CheckBox x:Name="MqttEnabled" Content="Publish all telemetry to MQTT"
                          Foreground="{StaticResource TextBrush}" Margin="2,6,0,0"/>
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Broker host" Style="{StaticResource Lbl}"/>
                        <TextBox x:Name="MqttHost"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Port" Style="{StaticResource Lbl}"/>
                        <TextBox x:Name="MqttPort"/>
                    </StackPanel>
                </Grid>
                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Username (optional)" Style="{StaticResource Lbl}"/>
                        <TextBox x:Name="MqttUser"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Password (optional)" Style="{StaticResource Lbl}"/>
                        <PasswordBox x:Name="MqttPass"/>
                    </StackPanel>
                </Grid>
                <TextBlock Text="Base topic" Style="{StaticResource Lbl}"/>
                <TextBox x:Name="MqttTopic"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="Cancel" Width="100" Height="40" Margin="0,0,10,0"
                        Style="{StaticResource LightButton}" Click="Cancel_Click"/>
                <Button Content="Save" Width="120" Height="40"
                        Style="{StaticResource SceneOn}" Click="Save_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
