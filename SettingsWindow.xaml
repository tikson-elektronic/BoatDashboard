<Window x:Class="BoatDashboard.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="560" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="Lbl">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="2,12,0,4"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource TrackBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="9,7"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{StaticResource TrackBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="9,7"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Border>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{StaticResource BgTop}" Offset="0"/>
                <GradientStop Color="{StaticResource BgBottom}" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Grid Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                <StackPanel>
                <TextBlock Text="Settings" Foreground="{StaticResource TextBrush}" FontSize="22" FontWeight="Bold"/>

                <TextBlock Text="CLAUDE AI" Style="{StaticResource SectionTitle}" Margin="0,18,0,2"/>
                <TextBlock Text="API key" Style="{StaticResource Lbl}"/>
                <PasswordBox x:Name="ApiKeyBox"/>
                <TextBlock Text="Stored locally in %AppData%\BoatDashboard. Used for the onboard assistant."
                           Foreground="{StaticResource MutedBrush}" FontSize="10" Margin="2,4,0,0" TextWrapping="Wrap"/>

                <TextBlock Text="VESSEL PAIRING (ALIVE CLOUD)" Style="{StaticResource SectionTitle}" Margin="0,20,0,2"/>
                <TextBlock x:Name="PairStatusText" Text="Not paired"
                           Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="2,4,0,0" TextWrapping="Wrap"/>
                <TextBlock Text="Pairing code" Style="{StaticResource Lbl}"/>
                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PairCodeBox" Grid.Column="0" CharacterCasing="Upper" MaxLength="12"
                             FontFamily="Consolas" FontSize="18"/>
                    <Button x:Name="PairButton" Grid.Column="2" Content="Pair" Height="38" VerticalAlignment="Bottom"
                            Style="{StaticResource SceneOn}" Click="Pair_Click"/>
                </Grid>
                <TextBlock x:Name="PairMsgText" Text="" Visibility="Collapsed"
                           FontSize="11" Margin="2,6,0,0" TextWrapping="Wrap"/>
                <Button x:Name="UnpairButton" Content="Unpair this PC" HorizontalAlignment="Left"
                        Height="32" Margin="0,8,0,0" Visibility="Collapsed"
                        Style="{StaticResource LightButton}" Click="Unpair_Click"/>
                <TextBlock x:Name="HardwareIdText" Text="" Foreground="{StaticResource MutedBrush}"
                           FontSize="10" Margin="2,8,0,0" TextWrapping="Wrap"/>

                <TextBlock Text="KIOSK / DISPLAY" Style="{StaticResource SectionTitle}" Margin="0,20,0,2"/>
                <CheckBox x:Name="KioskCheck" Content="Kiosk mode — fullscreen, hide cursor, always on top, locked"
                          Foreground="{StaticResource TextBrush}" FontSize="13" Margin="2,10,0,0"/>
                <CheckBox x:Name="BootCheck" Content="Launch automatically at Windows startup"
                          Foreground="{StaticResource TextBrush}" FontSize="13" Margin="2,10,0,0"/>
                <CheckBox x:Name="BlinkCheck" Content="Blink alarm indicators (uncheck for steady alarms)"
                          Foreground="{StaticResource TextBrush}" FontSize="13" Margin="2,10,0,0"/>
                <TextBlock Text="In kiosk mode the window has no chrome or cursor and stays on top. The only way to exit is the passcode below."
                           Foreground="{StaticResource MutedBrush}" FontSize="10" Margin="2,8,0,0" TextWrapping="Wrap"/>

                <TextBlock Text="ONBOARD PC" Style="{StaticResource SectionTitle}" Margin="0,20,0,2"/>
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="CPU LOAD" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="SemiBold"/>
                        <TextBlock x:Name="CpuLoadText" Text="—" Foreground="{StaticResource TextBrush}" FontSize="22" FontWeight="SemiBold" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="CPU TEMPERATURE" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="SemiBold"/>
                        <TextBlock x:Name="CpuTempText" Text="—" Foreground="{StaticResource TextBrush}" FontSize="22" FontWeight="SemiBold" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="NETWORK (LAN ACCESS)" Style="{StaticResource SectionTitle}" Margin="0,20,0,2"/>
                <TextBlock Text="Open the dashboard from any phone or tablet on the boat's Wi-Fi:"
                           Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="2,6,0,0" TextWrapping="Wrap"/>
                <TextBlock x:Name="NetUrlText" Text="—" Foreground="{StaticResource TextBrush}" FontSize="18"
                           FontWeight="SemiBold" FontFamily="Consolas" Margin="2,4,0,0"/>
                <TextBlock x:Name="NetDiscoveryText" Text="" Foreground="{StaticResource MutedBrush}"
                           FontSize="11" Margin="2,4,0,0" TextWrapping="Wrap"/>
                <TextBlock Text="Allowed devices — one IP or MAC per line. New devices must request access (they get a pairing page) and appear below for approval; accepting adds their MAC automatically."
                           Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="2,12,0,4" TextWrapping="Wrap"/>
                <TextBox x:Name="AllowListBox" AcceptsReturn="True" Height="92" FontFamily="Consolas" FontSize="13"
                         VerticalScrollBarVisibility="Auto" TextWrapping="NoWrap"/>
                <TextBlock Text="Connection requests" Foreground="{StaticResource MutedBrush}" FontSize="11"
                           FontWeight="SemiBold" Margin="2,12,0,4"/>
                <StackPanel x:Name="ReqPanel"/>

                <Grid Margin="0,20,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="LOGS" Style="{StaticResource SectionTitle}" Margin="0,0,0,0"/>
                    <Button Grid.Column="1" Content="Refresh" Height="26" Padding="10,0" VerticalAlignment="Center"
                            Style="{StaticResource LightButton}" Click="RefreshLogs_Click"/>
                </Grid>
                <Border BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="4" Margin="0,4,0,0">
                    <TextBox x:Name="LogsBox" IsReadOnly="True" FontFamily="Consolas" FontSize="11"
                             Height="150" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto" Background="{StaticResource TrackBrush}"
                             Foreground="{StaticResource MutedBrush}" BorderThickness="0"/>
                </Border>

                <TextBlock Text="CAMERAS / NVR" Style="{StaticResource SectionTitle}" Margin="0,20,0,2"/>
                <TextBlock Text="One camera per line:  Name | stream URL. Use an RTSP or MJPEG URL (e.g. Blue Iris: Salon | http://192.168.0.50:81/mjpg/salon )."
                           Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="2,6,0,4" TextWrapping="Wrap"/>
                <TextBox x:Name="CamerasBox" AcceptsReturn="True" Height="90" FontFamily="Consolas" FontSize="12"
                         VerticalScrollBarVisibility="Auto" TextWrapping="NoWrap"/>

                <TextBlock Text="SHUT DOWN" Style="{StaticResource SectionTitle}" Margin="0,20,0,2"/>
                <TextBlock Text="Enter the passcode to close the dashboard."
                           Foreground="{StaticResource MutedBrush}" FontSize="10" Margin="2,4,0,0" TextWrapping="Wrap"/>
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Passcode" Style="{StaticResource Lbl}"/>
                        <PasswordBox x:Name="KillPass"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="Shut Down" Height="34" VerticalAlignment="Bottom"
                            Style="{StaticResource LightButton}" Click="Kill_Click"/>
                </Grid>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="Cancel" Width="100" Height="40" Margin="0,0,10,0"
                        Style="{StaticResource LightButton}" Click="Cancel_Click"/>
                <Button Content="Save" Width="120" Height="40"
                        Style="{StaticResource SceneOn}" Click="Save_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
