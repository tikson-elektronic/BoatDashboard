<Window x:Class="BoatDashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BoatDashboard"
        Title="Boat System Dashboard" Height="860" Width="1200"
        MinHeight="640" MinWidth="920"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal">

    <Window.Resources>
        <!-- rounded gauge -->
        <Style x:Key="Gauge" TargetType="ProgressBar">
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{StaticResource TrackBrush}" CornerRadius="7">
                            <Grid>
                                <Border x:Name="PART_Track"/>
                                <Border x:Name="PART_Indicator" HorizontalAlignment="Left"
                                        Background="{TemplateBinding Foreground}" CornerRadius="7"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0.4,1">
                <GradientStop Color="{StaticResource BgTop}" Offset="0"/>
                <GradientStop Color="{StaticResource BgBottom}" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid Margin="26">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== Header ===== -->
            <Grid Grid.Row="0" Margin="4,0,4,22">
                <StackPanel>
                    <TextBlock Text="⚓  BOAT SYSTEM" Foreground="{StaticResource TextBrush}"
                               FontSize="26" FontWeight="Bold"/>
                    <TextBlock Text="Live monitoring &amp; control · IP2SL 192.168.0.100"
                               Foreground="{StaticResource MutedBrush}" FontSize="13" Margin="2,2,0,0"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Border Background="{StaticResource CardBrush}" CornerRadius="20" Padding="14,8"
                                BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="11" Height="11" Fill="{Binding ConnectionBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ConnectionText}" Foreground="{StaticResource TextBrush}"
                                           FontWeight="SemiBold" FontSize="13" Margin="9,0,0,0" VerticalAlignment="Center"/>
                                <Border Width="1" Background="{StaticResource StrokeBrush}" Margin="12,1,12,1"/>
                                <Ellipse Width="11" Height="11" Fill="{Binding MqttBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding MqttText}" Foreground="{StaticResource MutedBrush}"
                                           FontWeight="SemiBold" FontSize="12" Margin="9,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Button Content="⚙" FontSize="18" Width="44" Height="44" Margin="10,0,0,0"
                                Style="{StaticResource LightButton}" Click="Settings_Click" ToolTip="Settings"/>
                    </StackPanel>
                    <TextBlock Text="{Binding LastUpdated}" Foreground="{StaticResource MutedBrush}"
                               FontSize="11" HorizontalAlignment="Right" Margin="0,6,4,0"/>
                </StackPanel>
            </Grid>

            <!-- ===== Body ===== -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" Padding="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="1.05*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT: AC + Tanks -->
                    <StackPanel Grid.Column="0">

                        <TextBlock Text="AC MONITOR" Style="{StaticResource SectionTitle}"/>
                        <ItemsControl ItemsSource="{Binding Ac}" Margin="0,0,0,20">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><UniformGrid Columns="3"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                                        <StackPanel>
                                            <Grid>
                                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextBrush}"
                                                           FontWeight="SemiBold" FontSize="15"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <Ellipse Width="9" Height="9" Fill="{Binding Dot}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding StateText}" Foreground="{StaticResource MutedBrush}"
                                                               FontSize="10" FontWeight="SemiBold" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                            <TextBlock Text="{Binding VoltsText}" Foreground="{StaticResource TextBrush}"
                                                       FontSize="34" FontWeight="Bold" Margin="0,10,0,0"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <TextBlock Text="{Binding AmpsText}" Foreground="{StaticResource AccentBrush}"
                                                           FontSize="14" FontWeight="SemiBold"/>
                                                <TextBlock Text="  ·  " Foreground="{StaticResource MutedBrush}" FontSize="14"/>
                                                <TextBlock Text="{Binding HzText}" Foreground="{StaticResource MutedBrush}" FontSize="14"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="TANKS" Style="{StaticResource SectionTitle}"/>
                        <ItemsControl ItemsSource="{Binding Tanks}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><UniformGrid Columns="2"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Card}" Margin="0,0,12,12">
                                        <StackPanel>
                                            <Grid>
                                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextBrush}"
                                                           FontWeight="SemiBold" FontSize="14"/>
                                                <TextBlock Text="{Binding Display}" Foreground="{StaticResource TextBrush}"
                                                           FontSize="20" FontWeight="Bold" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <ProgressBar Style="{StaticResource Gauge}" Value="{Binding Percent}"
                                                         Foreground="{Binding Fill}" Margin="0,12,0,2"/>
                                            <TextBlock Text="{Binding Kind}" Foreground="{StaticResource MutedBrush}"
                                                       FontSize="10" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- RIGHT: Batteries + Lighting -->
                    <StackPanel Grid.Column="2">

                        <TextBlock Text="BATTERIES" Style="{StaticResource SectionTitle}"/>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                            <ItemsControl ItemsSource="{Binding Batteries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextBrush}"
                                                           FontSize="14" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding State}" Foreground="{StaticResource MutedBrush}"
                                                           FontSize="10" FontWeight="SemiBold" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Border Width="6" CornerRadius="3" Background="{Binding Brush}" Margin="0,2,12,2"/>
                                                <TextBlock Text="{Binding Display}" Foreground="{Binding Brush}"
                                                           FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <TextBlock Text="LIGHTING" Style="{StaticResource SectionTitle}"/>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <UniformGrid Columns="2" Margin="0,0,0,4">
                                    <Button Content="ALL ON" Style="{StaticResource SceneOn}" Margin="0,0,6,0"
                                            Click="AllOn_Click"/>
                                    <Button Content="ALL OFF" Style="{StaticResource SceneOff}" Margin="6,0,0,0"
                                            Click="AllOff_Click"/>
                                </UniformGrid>
                                <ItemsControl ItemsSource="{Binding Lights}" Margin="0,10,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource LightButton}" Margin="0,0,0,10"
                                                    Click="Light_Click" Tag="{Binding Code}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Width="4" CornerRadius="2" Background="{Binding Dot}"
                                                            Margin="0,2,12,2"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Ellipse Width="9" Height="9" Fill="{Binding Dot}" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding StateText}" Foreground="{Binding Dot}"
                                                                   FontSize="11" FontWeight="Bold" Margin="7,0,0,0" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="Lights are toggles — state reflects last command sent."
                                           Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="2,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="AI ASSISTANT" Style="{StaticResource SectionTitle}" Margin="6,20,0,10"/>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="✨" FontSize="16" VerticalAlignment="Center"/>
                                        <TextBlock Text="Claude" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"
                                                   FontSize="15" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding AssistantHint}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Foreground="{StaticResource MutedBrush}" FontSize="10"/>
                                </Grid>
                                <Border Background="{StaticResource TrackBrush}" CornerRadius="10" Margin="0,12,0,0" Height="200">
                                    <ScrollViewer x:Name="ChatScroll" VerticalScrollBarVisibility="Auto" Padding="12">
                                        <ItemsControl ItemsSource="{Binding Chat}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="10" Padding="10,7" Margin="0,0,0,8"
                                                            HorizontalAlignment="{Binding Align}" Background="{Binding Bubble}"
                                                            MaxWidth="320">
                                                        <TextBlock Text="{Binding Text}" Foreground="{StaticResource TextBrush}"
                                                                   FontSize="13" TextWrapping="Wrap"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="ChatInput" Grid.Column="0" Height="44"
                                             Background="{StaticResource TrackBrush}" Foreground="{StaticResource TextBrush}"
                                             CaretBrush="{StaticResource TextBrush}" BorderBrush="{StaticResource StrokeBrush}"
                                             BorderThickness="1" Padding="10,0" VerticalContentAlignment="Center"
                                             FontSize="13" KeyDown="ChatInput_KeyDown"/>
                                    <Button Grid.Column="1" Content="Send" Width="84" Height="44" Margin="10,0,0,0"
                                            Style="{StaticResource SceneOn}" Click="Send_Click"/>
                                </Grid>
                                <TextBlock Text="Try: &quot;all lights off&quot; · &quot;what's my fuel?&quot; · &quot;any low batteries?&quot;"
                                           Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="2,8,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
